{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "meridian-nexus-api",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "meridian-nexus-db",
      "database_id": "local-db-id"
    }
  ],
  "observability": {
    "enabled": true
  }
}
