# ─────────────────────────────────────────────────────────────
# Meridian Nexus — Frontend Environment Variables
# Copy this to apps/web/.env for local Vite React configuration.
# ─────────────────────────────────────────────────────────────

# URL of the Hono API Worker (requests will proxy in local mode automatically)
VITE_API_URL=http://localhost:8787

# Clerk Publishable Key (required for authentication)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Cloudflare Turnstile Site Key (bot verification widget, optional)
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
